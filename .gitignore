# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Environment files and secrets
*.env
*.env.*
*token.json*
*credentials.json*
*.pem

# Node / frontend dependencies
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build output
/build
/out
dist/
dist
/.next/
next-env.d.ts
*.tsbuildinfo

# Caches
.cache/
.ipynb_checkpoints/

# Testing / coverage
/coverage

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
dump.rdb
backend/logs/

# Python
__pycache__/
*.pyc
venv/
.venv/

# OS files
.DS_Store

# Deployment
.vercel

# Mobile / Android SDK
android-sdk/

# Data and databases
agenthub/agents/youtube/db
data/trade_journal.parquet
*.parquet

# Local video assets (too large for GitHub)
videos/

# Archives and large binaries
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Large validity reports (>100MB, debug artifacts)
backend/results/**/validity_report_*.jsonl
backend/results/**/bt_*.log
backend/results/bt_*.log

# Local-generated backtest outputs (timestamped)
backend/data/backtest_results/*_backtest_[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]_*
data/backtest_results/*_backtest_[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]_*
backend/results/*_job_[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]*
backend/run_*.py
backend/results/jobs/
backend/results/labs/mini_week/ui_*/
backend/results/labs/mini_week/wf_*/
backend/results/labs/mini_week/ifvg_*/
backend/results/labs/mini_week/smoke_ifvg_5m/
backend/results/labs/mini_week/debug_*/
backend/results/labs/mini_week/*_probe_*/
backend/results/labs/mini_week/*_postfix*/
backend/results/debug/

# Dev tooling artifacts
chainlit.md
.chainlit
.ac
test_result.md
